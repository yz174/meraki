{
  "name": "@agentflow/cli",
  "version": "0.0.1",
  "private": true,
  "description": "Ink v5 interactive CLI — agent REPL, log tailing, skill management",
  "bin": {
    "agentflow": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsc --project tsconfig.json --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "lint": "biome check src/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@agentflow/shared": "workspace:*",
    "ink": "^5.1.0",
    "react": "^19.0.0",
    "yargs": "^18.0.0",
    "chalk": "^5.4.1",
    "ora": "^8.1.1",
    "@inquirer/prompts": "^7.3.2",
    "cli-table3": "^0.6.5",
    "cli-boxes": "^3.0.0",
    "ky": "^1.7.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "^2.1.8",
    "@types/node": "^22.10.7",
    "@types/react": "^19.0.6",
    "@types/yargs": "^17.0.33"
  },
  "type": "module"
}
