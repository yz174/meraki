{
  "name": "@agentflow/gateway",
  "version": "0.0.1",
  "private": true,
  "description": "Fastify gateway — auth, rate limiting, webhooks, SSE, BullMQ enqueue",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "node --watch dist/index.js",
    "start": "node dist/index.js",
    "test": "vitest run",
    "lint": "biome check src/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@agentflow/shared": "workspace:*",
    "@agentflow/db": "workspace:*",
    "@agentflow/orchestration": "workspace:*",
    "fastify": "^5.2.1",
    "@fastify/jwt": "^9.1.0",
    "@fastify/rate-limit": "^10.2.2",
    "@fastify/helmet": "^13.0.1",
    "@fastify/cors": "^10.0.2",
    "@fastify/websocket": "^11.0.2",
    "bullmq": "^5.34.9",
    "ioredis": "^5.4.2",
    "pino": "^9.5.0",
    "zod": "^3.23.8",
    "@opentelemetry/sdk-node": "^0.57.2",
    "@opentelemetry/sdk-trace-base": "^1.30.1",
    "@opentelemetry/exporter-jaeger": "^1.30.0",
    "@opentelemetry/instrumentation-fastify": "^0.43.0",
    "prom-client": "^15.1.3",
    "@sentry/node": "^8.50.0"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "^2.1.8",
    "@types/node": "^22.10.7"
  },
  "type": "module"
}
