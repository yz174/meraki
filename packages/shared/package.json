{
  "name": "@agentflow/shared",
  "version": "0.0.1",
  "private": true,
  "description": "Shared Zod schemas, types, utilities and security primitives",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsc --project tsconfig.json --watch",
    "test": "vitest run",
    "lint": "biome check src/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "zod": "^3.23.8",
    "pino": "^9.5.0",
    "pino-roll": "^1.0.0",
    "yaml": "^2.7.0",
    "@opentelemetry/api": "^1.9.0"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "^2.1.8",
    "@types/node": "^22.10.7"
  },
  "type": "module"
}
