{
  "name": "@agentflow/runner",
  "version": "0.0.1",
  "private": true,
  "description": "Sandbox orchestration API — HMAC-authenticated HTTP API that spawns ephemeral containers",
  "main": "./dist/runner-api.js",
  "types": "./dist/runner-api.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsc --project tsconfig.json --watch",
    "start": "node dist/runner-api.js",
    "test": "vitest run",
    "lint": "biome check src/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@agentflow/shared": "workspace:*",
    "fastify": "^5.2.1",
    "@fastify/helmet": "^13.0.1",
    "dockerode": "^4.0.4",
    "execa": "^9.5.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "^2.1.8",
    "@types/node": "^22.10.7",
    "@types/dockerode": "^3.3.34"
  },
  "type": "module"
}
