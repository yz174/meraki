{
  "name": "@agentflow/core",
  "version": "0.0.1",
  "private": true,
  "description": "Agent runtime, tool definitions, LLM adapters — planning only, no execution",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsc --project tsconfig.json --watch",
    "test": "vitest run",
    "lint": "biome check src/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@agentflow/shared": "workspace:*",
    "@agentflow/db": "workspace:*",
    "@mastra/core": "^0.5.0",
    "ai": "^4.1.6",
    "@ai-sdk/anthropic": "^1.1.6",
    "@ai-sdk/openai": "^1.1.6",
    "ollama-ai-provider": "^1.2.0",
    "zod": "^3.23.8",
    "ioredis": "^5.4.2"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "^2.1.8",
    "@types/node": "^22.10.7"
  },
  "type": "module"
}
