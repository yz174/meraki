    "bullmq": "^5.34.9",
    "ioredis": "^5.4.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "^2.1.8",
    "@types/node": "^22.10.7"
  },
  "type": "module"
}
