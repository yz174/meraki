# =============================================================================
# AgentFlow — Environment Variables Reference
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Runtime Mode
# -----------------------------------------------------------------------------
RUNTIME_MODE=local
# local  → SQLite (plain) + local Qdrant binary + file secrets
# docker → Postgres + Qdrant sidecar + Redis + Docker secrets

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Local mode (SQLite — plain, no SQLCipher in dev)
DATABASE_URL=file:./state/db.sqlite
DATABASE_ENCRYPTION=none
# docker: DATABASE_ENCRYPTION=sqlcipher
# docker: DATABASE_URL=postgresql://agentflow:changeme@localhost:5432/agentflow

# DB encryption key (used when DATABASE_ENCRYPTION=sqlcipher)
DB_ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# Auth
# -----------------------------------------------------------------------------
AGENT_AUTH_TOKEN=
JWT_SECRET=
# Generate: openssl rand -hex 32

# -----------------------------------------------------------------------------
# LLM Providers (set whichever you use)
# -----------------------------------------------------------------------------
LLM_PROVIDER=anthropic
# anthropic | openai | ollama

ANTHROPIC_API_KEY=sk-ant-api03-...
OPENAI_API_KEY=sk-...
OLLAMA_BASE_URL=http://localhost:11434

# -----------------------------------------------------------------------------
# Embedding
# -----------------------------------------------------------------------------
EMBEDDING_PROVIDER=local
# local | openai
EMBEDDING_MODEL=nomic-embed-text-v1.5
# OpenAI fallback quota (daily token limit before circuit-breaker trips)
OPENAI_EMBEDDING_DAILY_TOKEN_LIMIT=1000000

# -----------------------------------------------------------------------------
# Qdrant (Vector DB)
# -----------------------------------------------------------------------------
QDRANT_URL=http://localhost:6333
QDRANT_GRPC_URL=http://localhost:6334
QDRANT_API_KEY=
QDRANT_MAX_VECTORS_PER_AGENT=500000

# -----------------------------------------------------------------------------
# Redis (BullMQ + session cache)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Runner Security
# -----------------------------------------------------------------------------
# Bind address: 127.0.0.1:8765 for local; 0.0.0.0:8765 in Docker internal network
RUNNER_BIND_ADDR=127.0.0.1:8765
RUNNER_INTERNAL_SECRET=
# Generate: openssl rand -hex 32
# Rotate: weekly (see docs/secret-rotation.md)

# Egress allowlist for sandbox containers (comma-separated domains)
RUNNER_EGRESS_ALLOWLIST=api.anthropic.com,api.openai.com

# -----------------------------------------------------------------------------
# Sandbox Timeouts (seconds)
# -----------------------------------------------------------------------------
SHELL_TIMEOUT=30
BROWSER_TIMEOUT=60
PYTHON_TIMEOUT=30

# -----------------------------------------------------------------------------
# Secrets Backend
# -----------------------------------------------------------------------------
SECRET_BACKEND=file
# file   → secrets.yaml (chmod 600) — local dev
# docker → /run/secrets/ — Docker mode
# vault  → HashiCorp Vault
VAULT_ADDR=https://vault.example.com
VAULT_TOKEN=hvs.xxx

# -----------------------------------------------------------------------------
# Connectors (optional — all disabled by default)
# -----------------------------------------------------------------------------
CONNECTOR_ENABLED_TELEGRAM=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_SECRET=

CONNECTOR_ENABLED_DISCORD=false
DISCORD_PUBLIC_KEY=

CONNECTOR_ENABLED_WHATSAPP=false
WHATSAPP_APP_SECRET=

# -----------------------------------------------------------------------------
# Observability (all optional)
# -----------------------------------------------------------------------------
SENTRY_DSN=
JAEGER_ENDPOINT=http://localhost:14268/api/traces

# -----------------------------------------------------------------------------
# Qdrant Audit Log Retention
# Hot storage: 90 days; Cold: 1 year (see docs/disaster-recovery.md)
# -----------------------------------------------------------------------------
AUDIT_LOG_HOT_DAYS=90
